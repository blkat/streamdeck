import { Theme } from "theme.slint";

export component ImageLibraryRow inherits Rectangle {
    in property <string> title;
    in property <bool> selected: false;
    callback clicked;

    height: 22px;
    background: selected ? #2ecc7122 : transparent;

    Text {
        text: root.title;
        color: selected ? white : #bbbbbb;
        font-size: 10px;
        font-weight: selected ? 600 : 400;
        x: 8px;
        width: parent.width - 16px;
        y: (parent.height - self.height) / 2;
        horizontal-alignment: left;
    }

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        width: parent.width;
        background: #3a3a3a;
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }
}

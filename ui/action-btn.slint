import { Theme } from "theme.slint";



// Bouton compact : zone cliquable pleine surface (texte sous TouchArea).

export component ActionBtn inherits Rectangle {

    in property <string> label: "";

    in property <brush> bg: Theme.btn;

    callback pressed;



    min-width: 64px;

    horizontal-stretch: 1;

    height: 44px;

    background: touch.has-hover ? Theme.btn-hover : bg;

    border-radius: 10px;

    border-width: 1px;

    border-color: Theme.key-border;



    Text {

        text: root.label;

        color: Theme.text;

        font-size: 9px;

        font-weight: 700;

        width: parent.width;

        horizontal-alignment: center;

        vertical-alignment: center;

    }



    touch := TouchArea {

        width: 100%;

        height: 100%;

        clicked => { root.pressed(); }

    }

}


import { Theme } from "theme.slint";



export component DeckKey inherits Rectangle {

    in property <string> title;

    in property <string> icon: "";

    in property <brush> key-color: Theme.btn;

    in property <bool> compact: true;

    in property <bool> mini: false;

    callback activated;



    width: mini ? 58px : (compact ? Theme.key-size : 88px);

    height: mini ? 50px : (compact ? Theme.key-size : 88px);

    background: touch.has-hover ? Theme.btn-hover : key-color;

    border-radius: Theme.key-radius;

    border-width: 1px;

    border-color: Theme.key-border;



    VerticalLayout {

        padding: 4px;

        spacing: 2px;

        alignment: center;

        if root.icon != "": Text {

            text: root.icon;

            font-size: mini ? 16px : 22px;

            horizontal-alignment: center;

        }

        Text {

            text: root.title;

            color: Theme.text;

            font-size: mini ? 8px : (compact ? 9px : 11px);

            font-weight: 700;

            horizontal-alignment: center;

            wrap: word-wrap;

        }

    }



    touch := TouchArea {

        width: 100%;

        height: 100%;

        clicked => { root.activated(); }

    }

}


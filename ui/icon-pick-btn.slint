export component IconPickBtn inherits Rectangle {

    in property <string> icon-id;

    in property <bool> selected: false;

    in property <image> icon-source;

    callback picked();



    width: 32px;

    height: 32px;

    background: selected ? #2ecc71 : #222222;

    border-radius: 6px;

    border-width: selected ? 1px : 0px;

    border-color: white;



    Image {

        source: root.icon-source;

        width: 22px;

        height: 22px;

        x: (parent.width - self.width) / 2;

        y: (parent.height - self.height) / 2;

    }



    touch := TouchArea {

        width: 100%;

        height: 100%;

        clicked => { root.picked(); }

    }

}


import { Theme } from "theme.slint";
import { HeaderBtn } from "header-btn.slint";

export component QuitBtn inherits Rectangle {
    callback clicked;

    width: Theme.header-btn-size;
    height: Theme.header-btn-size;
    background: touch.has-hover ? #b71c1c : #c62828;
    border-radius: 10px;
    border-width: 1px;
    border-color: #ff5252;

    Image {
        source: @image-url("icons/fermer.svg");
        width: 20px;
        height: 20px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }
}

export component AppTopBar inherits Rectangle {
    callback drag-request();
    callback quit();
    callback open-settings();
    callback toggle-edit();
    in property <string> page-path: "";
    in property <bool> edit-mode: false;

    private property <length> top-inset: 10px;
    private property <length> toolbar-h: Theme.header-btn-size;

    height: top-inset + toolbar-h + 4px;
    width: 100%;

    drag-strip := TouchArea {
        width: parent.width;
        height: parent.height;
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                root.drag-request();
            }
        }
    }

    left-tools := HorizontalLayout {
        spacing: 6px;
        x: 4px;
        y: top-inset;
        HeaderBtn {
            title: "";
            use-image-icon: true;
            icon-source: @image-url("icons/reglages.svg");
            key-color: Theme.tools;
            activated => { root.open-settings(); }
        }
        HeaderBtn {
            title: "";
            use-image-icon: true;
            active: root.edit-mode;
            icon-source: @image-url("icons/editer.svg");
            key-color: Theme.tools;
            activated => { root.toggle-edit(); }
        }
    }

    title-line := HorizontalLayout {
        spacing: 8px;
        alignment: center;
        x: (parent.width - self.width) / 2;
        y: top-inset + (toolbar-h - self.height) / 2;
        Text {
            text: "Streamdeck";
            color: #f0f0f0;
            font-size: 13px;
            font-weight: 700;
        }
        Text {
            text: "·";
            color: #666;
            font-size: 13px;
        }
        Text {
            text: root.page-path;
            color: Theme.accent;
            font-size: 13px;
            font-weight: 600;
        }
    }

    quit-btn := QuitBtn {
        x: parent.width - self.width - 4px;
        y: top-inset;
        clicked => { root.quit(); }
    }
}
